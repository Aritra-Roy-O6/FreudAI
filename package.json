{
  "name": "freudai",
  "version": "1.0.0",
  "description": "FreudAI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aritra-Roy-O6/FreudAI.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Aritra-Roy-O6/FreudAI/issues"
  },
  "homepage": "https://github.com/Aritra-Roy-O6/FreudAI#readme",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
  "appId": "com.freudai.app",
  "productName": "FreudAI",
  "directories": {
    "output": "dist"
  },
  "extraResources": [
    {
      "from": "engine/",
      "to": "engine/",
      "filter": [
        "**/*",
        "!**/__pycache__",
        "!**/*.pyc",
        "!**/*.py" 
      ]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "ui/favicon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  },
  "publish": [
    {
      "provider": "github",
      "owner": "AritraRoy",
      "repo": "FreudAI"
    }
  ]
}
}
